{
  "name": "ml-parfums",
  "version": "1.0.0",
  "description": "M&L Parfums storefront with a portable Node.js backend.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "db:import": "mysql -uroot < db/schema.sql",
    "db:export": "mysqldump -uroot --databases ml_parfums > db/export.sql"
  },
  "keywords": [
    "parfums",
    "storefront",
    "node"
  ],
  "author": "M&L Parfums",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "mariadb": "^3.5.2"
  }
}
